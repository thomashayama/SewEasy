# Copy to .env (never commit .env). docker-compose interpolates these
# automatically; for a bare `python gui.py` run, export them in your shell.

# --- Google OAuth ---
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud
# Console -> APIs & Services -> Credentials, with the authorized redirect URI
# set to GOOGLE_REDIRECT_URI below (add your production URL when deploying).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# --- Sessions ---
# Any long random string, e.g. from: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, an ephemeral secret is generated and sessions reset on restart.
JWT_SECRET=

# --- App location (controls Secure cookies + default redirect URI) ---
APP_URL=http://localhost:8080

# --- Database ---
# docker-compose overrides this to point at its postgres service. Without it,
# the app falls back to a local SQLite file at data/seweasy.db.
# DATABASE_URL=postgresql://seweasy:seweasy@localhost:5432/seweasy
